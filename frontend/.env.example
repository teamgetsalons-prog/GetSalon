# Frontend (.env.local for dev; set on Vercel for production)

# REQUIRED in production: must be the EXACT same value as the backend's
# AUTH_SECRET on Render. middleware.ts and server-api.ts verify the session
# JWT with it - if it's missing or different, every visitor looks logged out.
AUTH_SECRET=

# The site's own public URL (sitemap, share links, SEO).
# Production: https://www.getsalons.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_NAME=GetSalons Pakistan

# OPTIONAL: where /api/* is proxied (next.config.ts) and where server-side
# rendering fetches data from (server-api.ts). Defaults are built in:
# https://getsalon.onrender.com in production, http://localhost:3001 in dev.
# Only set this if the backend moves.
# API_PROXY_URL=

# NEXT_PUBLIC_API_URL is intentionally GONE. The browser now only ever talks
# to this site's own domain and the /api proxy forwards to the backend.
# Do not re-add it - a wrong value here broke production twice.
