# ── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/getsalons

# ── Auth (NextAuth / Auth.js v5) ────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=http://localhost:3000

# Google OAuth (future-ready — leave empty to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GetSalons Pakistan

# ── Cloudinary (image uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Nodemailer SMTP) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GetSalons Pakistan <no-reply@getsalons.pk>"

# ── WhatsApp (future integration — architecture ready) ──────
WHATSAPP_PROVIDER=console
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
